# NoneBot 基础配置
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
SUPERUSERS=["123456789"]
COMMAND_START=["/", ""]

# OneBot v11 连接 NapCat（推荐正向 WebSocket）
DRIVER=~fastapi+~websockets
ONEBOT_ACCESS_TOKEN=DC55hPS5YaCd8Y0~
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# 机器人信息
BOT_QQ=3371871293
BOT_NAME=小Q助手

# MiniMax 文生图
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_ASPECT_RATIO=1:1
MINIMAX_IMAGE_COUNT=1
MINIMAX_I2I_REFERENCE_TYPE=character

# MiniMax 语音合成（TTS）
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=male-qn-qingse
MINIMAX_TTS_EMOTION=happy

# 群聊随机插话（MiniMax 文本）
MINIMAX_CHAT_MODEL=MiniMax-M2.7
MINIMAX_CHAT_MAX_TOKENS=1536
GROUP_ROASTER_ENABLED=true
GROUP_ROASTER_MIN_TRIGGER=12
GROUP_ROASTER_MAX_TRIGGER=20
GROUP_ROASTER_CONTEXT_SIZE=15
BILIBILI_ROASTER_ENABLED=true

# AI Builder X 要闻
NEWS_DIGEST_ENABLED=true
NEWS_DIGEST_HOUR=8
NEWS_DIGEST_MINUTE=0
NEWS_DIGEST_TIMEZONE=Asia/Shanghai
NEWS_DIGEST_MAX_BUILDERS=8
NEWS_DIGEST_MAX_TWEETS=10
NEWS_DIGEST_DEFAULT_GROUP_IDS=946973502
NEWS_DIGEST_DEFAULT_USER_IDS=

# 每日群聊总结
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=0
DAILY_SUMMARY_MINUTE=30
DAILY_SUMMARY_TIMEZONE=Asia/Shanghai
DAILY_SUMMARY_HOURS=24
DAILY_SUMMARY_DEFAULT_GROUP_IDS=946973502
DAILY_SUMMARY_DEFAULT_USER_IDS=
DAILY_SUMMARY_SOURCE_GROUP_ID=946973502
